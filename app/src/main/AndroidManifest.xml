<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.MediCare">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_API_KEY_HERE" />

        <activity
            android:name=".auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MediCare.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".auth.OnboardingScreen01Activity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".auth.OnboardingScreen02Activity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".auth.OnboardingScreen03Activity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".auth.SignupActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".Patient.activities.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".Patient.activities.AllDoctorsActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".Patient.activities.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".Patient.activities.DoctorDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".Admin.activities.AdminMainActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

        <activity
            android:name=".Doctor.activities.DoctorMainActivity"
            android:exported="false"
            android:theme="@style/Theme.MediCare" />

    </application>

</manifest>