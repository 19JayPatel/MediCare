<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".Doctor.activities.AddDoctorActivity">

    <!-- Top Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded_white"
            android:elevation="2dp"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Add Doctor"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Personal Info Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PERSONAL INFO"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Full Name"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_person"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="Dr. Full Name"
                        android:inputType="textPersonName"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Designation"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etDesignation"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_designation_filled"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/primary"
                        android:hint="e.g. Senior Consultant"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Speciality"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etSpecialty"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_heart"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="e.g. Cardiologist"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Experience (Years)"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etExperience"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_time"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="e.g. 10 Years"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="About Doctor"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etAbout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:gravity="top"
                        android:hint="About Doctor"
                        android:inputType="textMultiLine"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Doctor Image URL"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etImageUrl"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_person"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="Doctor Image URL"
                        android:inputType="textUri"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Contact Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTACT"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Phone Number"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="+91 00000 00000"
                        android:inputType="phone"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Email Address"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="doctor@example.com"
                        android:inputType="textEmailAddress"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Clinic Details Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLINIC DETAILS"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Clinic / Hospital Name"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etClinicName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_hospital"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="e.g. Apollo Hospital"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Clinic Address"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etClinicAddress"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_location_outline"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="Full clinic address"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Consultation Fee (₹)"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etConsultationFee"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_rupee"
                        android:drawableEnd="@drawable/ic_arrow_drop_down"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="e.g. 500"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Service Hours Section (Hidden as availability is managed in ScheduleFragment) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERVICE HOURS"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Available Days"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etAvailableDays"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_calendar_outline"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="Mon, Tue, Wed, Thu, Fri"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Timing"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etStartTime"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/rounded_edittext_background"
                            android:backgroundTint="@color/bg"
                            android:drawableStart="@drawable/ic_time"
                            android:drawablePadding="12dp"
                            android:drawableTint="@color/text_tertiary"
                            android:hint="09:00 AM"
                            android:inputType="none"
                            android:focusable="false"
                            android:paddingStart="12dp"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/etEndTime"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/rounded_edittext_background"
                            android:backgroundTint="@color/bg"
                            android:drawableStart="@drawable/ic_time"
                            android:drawablePadding="12dp"
                            android:drawableTint="@color/text_tertiary"
                            android:hint="05:00 PM"
                            android:inputType="none"
                            android:focusable="false"
                            android:paddingStart="12dp"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Slot Duration"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etSlotDuration"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext_background"
                        android:backgroundTint="@color/bg"
                        android:drawableStart="@drawable/ic_time"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_tertiary"
                        android:hint="e.g. 30 Minutes"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Add Doctor Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddDoctor"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_rounded_button"
        android:backgroundTint="@color/accent"
        android:text="Add Doctor"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
